---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => {
    const dateA = new Date(a.data.date).getTime();
    const dateB = new Date(b.data.date).getTime();
    return dateB - dateA;
  })
  .slice(0, 3);
---

<Layout>

  <section class="hero">
    <img src="/sameer-rahman.jpg" alt="profile" />

    <div>
      <h1>Sameer Rahman</h1>
      <p>
        AI-powered SaaS products from idea to launch. Everything I build ships, improves over time, and evolves in public.
      </p>

      <div class="socials">
        <a href="https://twitter.com/iamsameerrahman" target="_blank"><i class="fa-brands fa-twitter"></i></a>
        <a href="https://github.com/rahmansameer" target="_blank"><i class="fa-brands fa-github"></i></a>
        <a href="https://linkedin.com/in/rahmansameer" target="_blank"><i class="fa-brands fa-linkedin"></i></a>
        <a href="https://facebook.com/iamsameerrahman" target="_blank"><i class="fa-brands fa-facebook"></i></a>
      </div>
    </div>
  </section>

<section class="projects">
  <h2>Projects</h2>

  <div class="project">
    <h3>
      <a href="https://github.com/rahmansameer/polar-desk" target="_blank">
        Polar Desk
      </a>
    </h3>

    <p>
      A client portal built for service teams to manage projects, streamline communication, and keep everything organized in one workspace.
    </p>

    <div class="stack">
      <span>Next.js</span>
      <span>React</span>
      <span>Supabase</span>
      <span>Tailwind</span>
      <span>Stripe</span>
    </div>
  </div>

  <div class="project">
    <h3>
      <a href="https://github.com/rahmansameer/appbase" target="_blank">
        Appbase
      </a>
    </h3>

    <p>
      An AI-powered platform to discover, evaluate, and compare software with structured insights and intelligent recommendations.
    </p>

    <div class="stack">
      <span>Next.js</span>
      <span>React</span>
      <span>Supabase</span>
      <span>Tailwind</span>
      <span>AI APIs</span>
    </div>
  </div>
</section>

<section class="stack-section">
  <h2>Tech Stack</h2>

  <div class="stack-grid">

    <div class="stack-card">
      <h3>Frontend</h3>
      <div class="stack-items">
        <span>React</span>
        <span>JavaScript</span>
        <span>Tailwind</span>
      </div>
    </div>

    <div class="stack-card">
      <h3>Backend</h3>
      <div class="stack-items">
        <span>Node.js</span>
        <span>Python</span>
        <span>Express.js</span>
      </div>
    </div>

    <div class="stack-card">
      <h3>Databases</h3>
      <div class="stack-items">
        <span>PostgreSQL</span>
        <span>MongoDB</span>
        <span>Redis</span>
      </div>
    </div>

    <div class="stack-card">
      <h3>Tools</h3>
      <div class="stack-items">
        <span>Git</span>
        <span>GitHub</span>
        <span>VS Code</span>
      </div>
    </div>

  </div>
</section>


<section class="github">
  <h2>GitHub Activity</h2>

  <div class="github-graph">
    <img 
      src="https://ghchart.rshah.org/rahmansameer" 
      alt="GitHub contribution graph"
    />
  </div>
</section>
  

  <section class="posts">
    <h2>Recent Posts</h2>

    {posts.map((post) => (
      <div class="post">
        <a href={`/post/${post.id}`}>
          <h3>{post.data.title}</h3>
          <p>{post.data.date}</p>
          <p>
            {post.body
              ?.replace(/[#>*_\-]/g, '')
              .slice(0, 120)}...
          </p>
        </a>
      </div>
    ))}

    <a href="/post" class="all-posts">
      All Posts <i class="fa-solid fa-arrow-right"></i>

    </a>
  </section>

  <style>
    .hero {
      display: flex;
      gap: 18px;
      align-items: center;
    }

    .hero img {
      width: 90px;
      height: 90px;
      border-radius: 999px;
      object-fit: cover;
    }

    .hero h1 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
    }

    .hero p {
      margin-top: 6px;
      color: #aaa;
      font-size: 14px;
      line-height: 1.5;
    }

    body.light .hero p {
      color: #555;
    }

    .socials {
      margin-top: 10px;
    }

    .socials a {
      margin-right: 14px;
      color: inherit;
      font-size: 15px;
      opacity: 0.8;
    }

    .socials a:hover {
      opacity: 1;
    }

    .projects {
  margin-top: 60px;
}

.projects h2 {
  margin-bottom: 20px;
  font-size: 18px;
  font-weight: 600;
}

.project {
  margin-bottom: 28px;
}

.project h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 500;
}

.project p {
  margin: 6px 0 10px;
  font-size: 13px;
  color: #aaa;
  line-height: 1.5;
}

/* Stack (boxed) */
.stack span {
  display: inline-block;
  font-size: 11px;
  padding: 4px 8px;
  margin-right: 6px;
  margin-top: 6px;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.03);
  color: #aaa;
}

.project h3 a {
  text-decoration: none;
  color: inherit;
  opacity: 0.9;
}

.project h3 a:hover {
  text-decoration: underline;
  opacity: 1;
}

/* Light mode */
body.light .project p {
  color: #555;
}

.stack-section {
  margin-top: 60px;
}

.stack-section h2 {
  margin-bottom: 20px;
  font-size: 18px;
  font-weight: 600;
}

/* GRID instead of vertical stack */
.stack-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}

/* Card style */
.stack-card {
  padding: 16px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.147);
  background: rgba(255,255,255,0.02);
  transition: all 0.2s ease;
}


/* Title */
.stack-card h3 {
  margin: 0 0 10px;
  font-size: 13px;
  font-weight: 500;
  color: #aaa;
}

/* Chips */
.stack-items span {
  display: inline-block;
  font-size: 11px;
  padding: 5px 9px;
  margin-right: 6px;
  margin-top: 6px;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.03);
  color: #aaa;
}

/* Light mode */
body.light .stack-card {
  background: #fafafa61;
  border: 1px solid #e5e5e5;
}


body.light .stack-card h3 {
  color: #666;
}

body.light .stack-items span {
  background: #fff;
  border: 1px solid #e5e5e5;
  color: #555;
}

/* Mobile */
@media (max-width: 640px) {
  .stack-grid {
    grid-template-columns: 1fr;
  }
}


.github {
  margin-top: 60px;
}

.github h2 {
  margin-bottom: 20px;
  font-size: 18px;
  font-weight: 600;
}

.github-graph {
  width: 100%;
  overflow-x: auto;
}

.github-graph img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
}

body.light .stack span {
  background: #fafafa;
  border: 1px solid #e5e5e5;
  color: #555;
}

    .posts {
      margin-top: 50px;
    }

    .posts h2 {
      margin-bottom: 20px;
      font-size: 18px;
      font-weight: 600;
    }

    .post {
      margin-bottom: 26px;
    }

    .post a {
      text-decoration: none;
      color: inherit;
    }

    .post h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 500;
    }

    .post p {
      margin: 6px 0;
      color: #aaa;
      font-size: 13px;
    }

    body.light .post p {
      color: #666;
    }

    .all-posts {
      display: inline-block;
      margin-top: 10px;
      font-size: 14px;
      color: inherit;
      opacity: 0.8;
      text-decoration: none;
    }

    .all-posts:hover {
      opacity: 1;
      text-decoration: underline;
    }
  </style>

</Layout>