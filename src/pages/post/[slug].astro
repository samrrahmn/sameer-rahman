---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title}>

  <div class="post-container">

    <a href="/" class="back">
      <i class="fa-solid fa-arrow-left"></i>
      Back
    </a>

    <h1 class="title">{post.data.title}</h1>
    <div class="date">{post.data.date}</div>

    <article class="post-content">
      <Content />
    </article>

  </div>

  <style is:global>
    .post-container {
      margin-top: 10px;
      max-width: 600px;
    }

    .back {
      font-size: 13px;
      color: #aaa;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 24px;
      text-decoration: none !important;
      opacity: 0.8;
    }

    .back:hover {
      opacity: 1;
    }

    .title {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .date {
      font-size: 13px;
      color: #aaa;
      margin-bottom: 28px;
    }

    .post-content p {
      font-size: 14px;
      line-height: 1.7;
      color: #aaa;
      margin-bottom: 18px;
    }

    body.light .post-content p {
      color: #555;
    }

    .post-content h2 {
      font-size: 16px;
      font-weight: 600;
      margin-top: 24px;
      margin-bottom: 10px;
      color: white;
    }

    .post-content h3 {
      font-size: 15px;
      font-weight: 600;
      margin-top: 20px;
      margin-bottom: 8px;
      color: white;
    }

    body.light .post-content h2,
    body.light .post-content h3 {
      color: black;
    }

    .post-content li {
      font-size: 14px;
      color: #aaa;
      margin-bottom: 6px;
    }

    body.light .post-content li {
      color: #555;
    }

    .post-content img {
      width: 100%;
      border-radius: 8px;
      margin: 20px 0;
    }

    .post-content blockquote {
      margin: 20px 0;
      padding-left: 12px;
      border-left: 2px solid #aaa;
      color: #aaa;
    }

    body.light .post-content blockquote {
      color: #555;
    }
  </style>

</Layout>